# ── LLM Provider ──────────────────────────────────────────────────────────────
# You can configure the provider in-app (recommended), or set it here as a fallback.
#
# Anthropic (default)
ANTHROPIC_API_KEY=your_key_here
#
# OpenAI
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
#
# Google Gemini
# LLM_MODEL=gemini/gemini-1.5-pro
# GEMINI_API_KEY=AIza...
#
# Ollama (local, no key needed — make sure Ollama is running)
# LLM_MODEL=ollama/llama3.1
